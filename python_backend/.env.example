# ---- Database (required for production, optional for local dev) ----
# DATABASE_URL=postgresql://user:pass@localhost:5432/negotiation

# ---- Redis (optional, enables multi-instance WebSocket broadcasting) ----
# REDIS_URL=redis://localhost:6379

# ---- LLM models (LiteLLM format: provider/model) ----
LLM_MODEL_FAST=openai/gpt-5.4-nano
LLM_MODEL_BALANCED=openai/gpt-5.4-mini
LLM_MODEL_QUALITY=openai/gpt-5.4-pro
# Embedding model: use `local/<name>` for in-process sentence-transformers (no API key),
# or an OpenAI/HF-style name (e.g. `openai/text-embedding-3-small`) to route via LiteLLM.
EMBEDDING_MODEL=local/all-MiniLM-L6-v2

# ---- LLM API keys (set what you need for your configured models) ----
# HUGGINGFACE_API_KEY=hf_xxx
OPENAI_API_KEY=sk-WfN3ioFmE5DJGOZi0_hzsA
OPENAI_API_BASE=https://ai-gateway.andrew.cmu.edu
# ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Auth (optional — if set, all endpoints require X-API-Key header) ----
# API_KEY=your-secret-api-key

# ---- CORS (comma-separated allowed origins) ----
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Rate limiting ----
RATE_LIMIT=30/minute

# ---- STT (Faster-Whisper, requires ffmpeg) ----
STT_ENABLED=true
STT_MODEL_SIZE=small
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto

# ---- TTS (Kokoro-82M + Gemini for quality mode emotion tags) ----
TTS_ENABLED=true
TTS_DEVICE=auto
# GEMINI_API_KEY=your-gemini-api-key  # enables emotion-aware TTS in quality mode

# ---- Server ----
PORT=8000
